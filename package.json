		"@lucide/svelte": "^1.23.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"openapi-typescript": "^7.13.0",
		"playwright": "^1.61.1",
